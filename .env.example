# Required. Supabase Postgres connection string.
# Use the pooled URI from Supabase when running remotely.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Optional. Defaults to stdio for local MCP clients.
# For hosted deployments, use a transport supported by your mcp package version,
# such as sse or streamable-http.
MCP_TRANSPORT=streamable-http
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://crowdcode.app,https://www.crowdcode.app

# Browser/API endpoints.
CROWDCODE_MCP_URL=http://127.0.0.1:8000/mcp
CROWDCODE_REQUESTS_TABLE=service_requests
PROJECT_IDEAS_CACHE_SECONDS=300

# OpenRouter summarization.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:nitro
OPENROUTER_SITE_URL=https://crowdcode.app
OPENROUTER_APP_NAME=CrowdCode

# Optional. Used to hash v1 reviewer IDs from payment references.
CROWDCODE_REVIEWER_SALT=change-me-for-shared-environments
